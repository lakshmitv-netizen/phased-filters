{
  "name": "forecasting-planning-tool",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "node ./node_modules/vite/bin/vite.js",
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "node ./node_modules/vite/bin/vite.js preview",
    "tokens-pdf": "node generate-planning-grid-design-tokens-pdf.cjs",
    "start": "node server.js",
    "start:vite": "node ./node_modules/vite/bin/vite.js preview --host 0.0.0.0 --port ${PORT:-5000}"
  },
  "dependencies": {
    "@salesforce-ux/design-system": "^2.29.0",
    "@vitejs/plugin-react": "^4.3.4",
    "express": "^4.18.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.11.0",
    "vite": "^5.4.11"
  },
  "devDependencies": {
    "@types/node": "^25.0.3",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@types/react-router-dom": "^5.3.3",
    "@typescript-eslint/eslint-plugin": "^8.18.1",
    "@typescript-eslint/parser": "^8.18.1",
    "eslint": "^9.17.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "puppeteer": "^24.34.0",
    "typescript": "~5.6.2"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
